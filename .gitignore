data/inbox/
data/large_data_set
tmp/
tmp*/

# MCP / localdev runtime artifacts
localdev/**/__pycache__/
localdev/**/*.pyc

# Docker / compose
docker-compose.override.yml
*.local

# Other
*.sqlite3
