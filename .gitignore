# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual envs
.venv/
venv/
env/
ENV/

# Packaging/build
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Dependency lock files (if you prefer not to commit local lock files)
uv.lock

# Editor and OS files
.vscode/
.idea/
.DS_Store
*.swp

# Test / cache
.pytest_cache/
.mypy_cache/

# Logs
*.log

